# MEG Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is git-ignored.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://meg:changeme@localhost:5432/meg
POSTGRES_DB=meg
POSTGRES_USER=meg
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Polygon RPC (Alchemy preferred per OQ-01) ─────────────────────────────────
POLYGON_RPC_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE
ALCHEMY_API_KEY=YOUR_KEY_HERE

# ── Polymarket CLOB ───────────────────────────────────────────────────────────
POLYMARKET_API_KEY=YOUR_KEY_HERE
POLYMARKET_API_SECRET=YOUR_KEY_HERE
POLYMARKET_API_PASSPHRASE=YOUR_KEY_HERE
# WARNING: Private key for trade execution. Guard carefully. See OQ-05.
POLYMARKET_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_APPROVAL_CHAT_ID=YOUR_CHAT_ID_HERE

# ── Trading mode ──────────────────────────────────────────────────────────────
# NEVER set PAPER_TRADING=false without explicit team review and confirmation.
PAPER_TRADING=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
